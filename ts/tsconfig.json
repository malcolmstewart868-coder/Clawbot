{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "moduleResolution": "node16",
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "api/**/*.ts",
    "app/**/*.ts",
    "config/**/*.ts",
    "core/**/*.ts",
    "data/**/*.ts",
    "scripts/**/*.ts",
    "shared/**/*.ts",
    "*.ts"
  ],
  "exclude": [
    "node_modules",
    "storage",
    "storage_stress",
    "stress",
    "tests",
    "ui",
    "venv",
    "**/dist/**",
    "**/build/**"
  ]
}