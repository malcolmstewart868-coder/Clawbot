{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "moduleResolution": "node16",
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "ts/**/*.ts",
    "src/**/*.ts",
    "scripts/**/*.ts",
    "shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "MirrorModel",
    "ui",
    "**/.history",
    "**/.vscode",
    "**/AppData/**",
    "**/History/**"
  ]
}