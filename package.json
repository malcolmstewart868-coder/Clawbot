{
  "name": "clawbot-root",
  "private": true,
  "scripts": {
    "boot": "concurrently -n API,UI -c auto \"npm run api\" \"npm run ui\"",
    "api": "npm run dev --prefix ts",
    "ui": "npm run dev --prefix ui",
    "stop": "node scripts/stop-ports.mjs",
    "stress:summary": "ts-node --project ts/tsconfig.json scripts/summarize-blackbox.ts"

  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
